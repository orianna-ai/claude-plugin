  "typesMap": {
    "Ace": {
      "exclude": [
        [
          "^",
          1,
          "/.*"
        ]
      ],
      "match": "^(.*)\\/ace.js",
      "types": [
        "ace"
      ]
    },
    "Datatables.net": {
      "match": "^.*\\/(jquery\\.)?dataTables(\\.all)?(\\.min)?\\.js$",
      "types": [
        "datatables.net"
      ]
    },
    "Kendo": {
      "exclude": [
        [
          "^",
          1,
          "/.*"
        ]
      ],
      "match": "^(.*\\/kendo(-ui)?)\\/kendo\\.all(\\.min)?\\.js$",
      "types": [
        "kendo-ui"
      ]
    },
    "Office Nuget": {
      "exclude": [
        [
          "^",
          1,
          "/.*"
        ]
      ],
      "match": "^(.*\\/office\\/1)\\/excel-\\d+\\.debug\\.js$",
      "types": [
        "office"
      ]
    },
    "References": {
      "exclude": [
        [
          "^",
          1,
          "$"
        ]
      ],
      "match": "^(.*\\/_references\\.js)$"
    },
    "WinJS": {
      "exclude": [
        [
          "^",
          1,
          "/.*"
        ]
      ],
      "match": "^(.*\\/winjs-[.\\d]+)\\/js\\/base\\.js$",
      "types": [
        "winjs"
      ]
    },
    "jquery": {
      "match": "jquery(-(\\.?\\d+)+)?(\\.intellisense)?(\\.min)?\\.js$",
      "types": [
        "jquery"
      ]
    }
  }
}
