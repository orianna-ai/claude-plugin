{
  "author": "atomiks",
  "bugs": "https://github.com/floating-ui/floating-ui",
  "dependencies": {
    "@floating-ui/utils": "^0.2.11"
  },
  "description": "Positioning library for floating elements: tooltips, popovers, dropdowns, and more",
  "devDependencies": {
    "config": "0.0.0"
  },
  "exports": {
    ".": {
      "default": "./dist/floating-ui.core.umd.js",
      "import": {
        "default": "./dist/floating-ui.core.mjs",
        "types": "./dist/floating-ui.core.d.mts"
      },
      "module": "./dist/floating-ui.core.esm.js",
      "types": "./dist/floating-ui.core.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://floating-ui.com",
  "keywords": [
    "tooltip",
    "popover",
    "dropdown",
    "menu",
    "popup",
    "positioning"
  ],
  "license": "MIT",
  "main": "./dist/floating-ui.core.umd.js",
  "module": "./dist/floating-ui.core.esm.js",
  "name": "@floating-ui/core",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "packages/core",
    "type": "git",
    "url": "https://github.com/floating-ui/floating-ui.git"
  },
  "scripts": {
    "build": "rollup -c",
    "build:api": "build-api --tsc tsconfig.lib.json",
    "clean": "rimraf dist out-tsc",
    "dev": "rollup -c -w",
    "format": "prettier --write .",
    "lint": "eslint .",
    "publint": "publint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc -b"
  },
  "sideEffects": false,
  "types": "./dist/floating-ui.core.d.ts",
  "unpkg": "./dist/floating-ui.core.umd.min.js",
  "version": "1.7.5"
}
