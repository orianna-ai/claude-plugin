{
  "author": "Anton Korzunov <thekashey@gmail.com>",
  "dependencies": {
    "react-remove-scroll-bar": "^2.3.7",
    "react-style-singleton": "^2.2.3",
    "tslib": "^2.1.0",
    "use-callback-ref": "^1.3.3",
    "use-sidecar": "^1.1.3"
  },
  "description": "Disables scroll outside of `children` node.",
  "devDependencies": {
    "@babel/core": "^7.17.9",
    "@size-limit/preset-small-lib": "^11.0.2",
    "@storybook/react": "^6.4.22",
    "@theuiteam/lib-builder": "^0.1.4",
    "@types/enzyme-adapter-react-16": "^1.0.6",
    "@types/react": "^18.0.0",
    "babel-loader": "^8.2.4",
    "enzyme-adapter-react-16": "^1.15.6",
    "size-limit": "^11.0.2"
  },
  "engines": {
    "node": ">=10"
  },
  "files": [
    "dist",
    "UI",
    "sidecar"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "jsnext:main": "dist/es2015/index.js",
  "keywords": [
    "scroll"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{js,css,json,md}": [
      "prettier --write",
      "git add"
    ],
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  },
  "main": "dist/es5/index.js",
  "module": "dist/es2015/index.js",
  "module:es2019": "dist/es2019/index.js",
  "name": "react-remove-scroll",
  "packageManager": "yarn@1.22.19",
  "peerDependencies": {
    "@types/react": "*",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "prettier": {
    "printWidth": 120,
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5"
  },
  "repository": "https://github.com/theKashey/react-remove-scroll",
  "resolutions": {
    "@types/react": "^18.0.0",
    "tslib": "^2.1.0"
  },
  "scripts": {
    "build": "lib-builder build && yarn size:report",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:rewrite": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "dev": "lib-builder dev",
    "format": "lib-builder format",
    "lint": "lib-builder lint",
    "prepublish": "yarn build && yarn changelog",
    "release": "yarn build && yarn test",
    "size": "size-limit",
    "size:report": "size-limit --json > .size.json",
    "storybook": "start-storybook -p 6006",
    "test": "jest",
    "test:ci": "jest --runInBand --coverage",
    "update": "lib-builder update"
  },
  "sideEffects": [
    "**/sidecar.js"
  ],
  "types": "dist/es5/index.d.ts",
  "version": "2.7.2"
}
