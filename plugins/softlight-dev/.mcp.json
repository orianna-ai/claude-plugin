{
  "mcpServers": {
    "softlight": {
      "type": "http",
      "url": "http://localhost:8080/mcp/"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--browser",
        "chromium",
        "--isolated",
        "--no-sandbox",
        "--viewport-size",
        "1512x982"
      ]
    }
  }
}

