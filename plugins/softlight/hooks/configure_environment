#!/usr/bin/env bash

# load the session start event
CLAUDE_CODE_SESSION_START_EVENT=$(cat)

# inject it into conversation context so the model can see it
jq -n --arg ctx "CLAUDE_CODE_SESSION_START_EVENT=$CLAUDE_CODE_SESSION_START_EVENT" \
  '{ hookSpecificOutput: { hookEventName: "SessionStart", additionalContext: $ctx } }'

# inject into shell environment so Bash tool calls can use it
if [[ -n "$CLAUDE_ENV_FILE" ]]; then
  grep -q "CLAUDE_CODE_SESSION_START_EVENT" "$CLAUDE_ENV_FILE" 2>/dev/null \
    || printf 'export CLAUDE_CODE_SESSION_START_EVENT=%q\n' "$CLAUDE_CODE_SESSION_START_EVENT" >>"$CLAUDE_ENV_FILE"
  grep -q "CLAUDE_CODE_EFFORT_LEVEL" "$CLAUDE_ENV_FILE" 2>/dev/null \
    || printf 'export CLAUDE_CODE_EFFORT_LEVEL=max\n' >>"$CLAUDE_ENV_FILE"
fi

# Force max effort. Three redundant mechanisms because effort propagation is
# buggy across Claude Code versions:
#   1. Skill/agent frontmatter `effort: max` (canonical, per-component)
#   2. .claude/settings.local.json effortLevel (loaded by parent + all subagents)
#   3. CLAUDE_CODE_EFFORT_LEVEL env var in CLAUDE_ENV_FILE (issue #41028 workaround)
SETTINGS_LOCAL="$PWD/.claude/settings.local.json"
if [[ -f "$SETTINGS_LOCAL" ]]; then
  CURRENT_EFFORT=$(jq -r '.effortLevel // empty' "$SETTINGS_LOCAL" 2>/dev/null)
  if [[ "$CURRENT_EFFORT" != "max" ]]; then
    jq '. + {"effortLevel": "max"}' "$SETTINGS_LOCAL" > "$SETTINGS_LOCAL.tmp" \
      && mv "$SETTINGS_LOCAL.tmp" "$SETTINGS_LOCAL"
  fi
else
  mkdir -p "$(dirname "$SETTINGS_LOCAL")"
  echo '{"effortLevel": "max"}' > "$SETTINGS_LOCAL"
fi