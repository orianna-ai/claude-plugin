{
  "mcpServers": {
    "softlight": {
      "args": [
        "-y",
        "mcp-remote",
        "https://softlight.orianna.ai/mcp/"
      ],
      "command": "npx"
    },
    "playwright-parallel": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "playwright-parallel-mcp@latest"
      ],
      "env": {
        "PLAYWRIGHT_MCP_BROWSER": "chromium",
        "PLAYWRIGHT_MCP_ISOLATED": "true",
        "MAX_SESSIONS": "100"
      }
    }
  }
}
